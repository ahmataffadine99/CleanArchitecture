{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "paths": {
      "@ecoeats/domain": ["../../packages/domain/src"],
      "@ecoeats/application": ["../../packages/application/src"],
      "@ecoeats/infrastructure": ["../../packages/infrastructure/src"],
      "@ecoeats/interface": ["../../packages/interface/src"]
    }
  },
  "include": ["src/**/*"]
}
