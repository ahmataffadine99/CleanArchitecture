// Schéma Prisma pour PostgreSQL (adaptateur 2)
// Pour activer : DB_ADAPTER=postgresql dans les variables d'environnement

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id             String     @id
  nom            String
  email          String     @unique
  adresse        String
  telephone      String?
  pointsFidelite Int        @default(0)
  commandes      Commande[]
}

model Restaurant {
  id             String     @id
  nom            String
  adresse        String
  latitude       Float
  longitude      Float
  proprietaireId String
  imageUrl       String?
  plats          PlatMenu[]
  commandes      Commande[]
}

model PlatMenu {
  id              String     @id
  nom             String
  description     String
  prixCentimes    Int
  allergenes      String[]
  stockJournalier Int
  restaurantId    String
  imageUrl        String?
  actif           Boolean    @default(true)
  categorie       String     @default("PLAT") // "PLAT" ou "BOISSON"
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
}

model FavoriRestaurant {
  clientId     String
  restaurantId String

  @@id([clientId, restaurantId])
}

model FavoriPlat {
  clientId String
  platId   String

  @@id([clientId, platId])
}

model AvisLivreur {
  id          String   @id @default(uuid())
  commandeId  String   @unique
  livreurId   String
  clientId    String
  note        Int // 1 à 5
  commentaire String?
  creeLe      DateTime @default(now())
}

model Commande {
  id                   String            @id
  clientId             String
  restaurantId         String
  statut               String
  prixPlatsCentimes    Int
  fraisLivCentimes     Int
  fraisServiceCentimes Int
  reductionCentimes    Int               @default(0)
  adresseLivraison     String
  livreurId            String?
  tempsPreparation     Int?
  latitudeLivraison    Float?
  longitudeLivraison   Float?
  creeLe               DateTime          @default(now())
  client               Client            @relation(fields: [clientId], references: [id])
  restaurant           Restaurant        @relation(fields: [restaurantId], references: [id])
  articles             ArticleCommande[]
  facture              Facture?
}

model ArticleCommande {
  id           String   @id @default(uuid())
  commandeId   String
  menuItemId   String
  nom          String
  prixCentimes Int
  quantite     Int
  restaurantId String
  commande     Commande @relation(fields: [commandeId], references: [id])
}

model Facture {
  id         String   @id
  commandeId String   @unique
  clientId   String
  genereLe   DateTime @default(now())
  total      Int
  commande   Commande @relation(fields: [commandeId], references: [id])
}

model Livreur {
  id                   String   @id
  nom                  String
  telephone            String
  latitude             Float
  longitude            Float
  statut               String   @default("INDISPONIBLE")
  portefeuilleCentimes Int      @default(0)
  estExpert            Boolean  @default(false)
  commandesEnCoursIds  String[]
  propositionsIds      String[]
  currentRestaurantId  String?
}

model CompteUtilisateur {
  id              String   @id
  email           String   @unique
  motDePasseHache String
  role            String // "CLIENT", "RESTAURATEUR", "LIVREUR"
  profilId        String // ID du profil associé
  creeLe          DateTime @default(now())
}
